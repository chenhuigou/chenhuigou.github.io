{% assign experiences = site.data.cv.cv.sections.Experience %}

<div class="experience-timeline">
  <div class="timeline-track">
    <div class="timeline-line"></div>
    <div class="timeline-line-fill"></div>
  </div>
  {% for exp in experiences %}
  <div class="timeline-item" data-index="{{ forloop.index0 }}">
    <div class="timeline-dot">
      {% if forloop.first %}<div class="dot-pulse"></div>{% endif %}
    </div>
    <div class="timeline-card">
      <div class="timeline-date">
        {{ exp.start_date }}{% if exp.end_date and exp.end_date != "" %} — {{ exp.end_date }}{% else %} — Present{% endif %}
      </div>
      <div class="timeline-company">{{ exp.company }}</div>
      <div class="timeline-position">{{ exp.position }}</div>
      {% if exp.location %}
        <div class="timeline-location">📍 {{ exp.location }}</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
