{% assign experiences = site.data.cv.cv.sections.Experience %}

<div class="h-timeline-wrapper">
  <div class="h-timeline-scroll" id="timeline-scroll">
    <div class="h-timeline-track">
      <!-- The horizontal line -->
      <div class="h-timeline-line"></div>
      <div class="h-timeline-line-glow"></div>

      {% for exp in experiences reversed %}
      <div class="h-timeline-node{% if forloop.last %} current{% endif %}" data-index="{{ forloop.index0 }}">
        <div class="h-timeline-dot">
          {% if forloop.last %}<div class="h-dot-pulse"></div>{% endif %}
        </div>
        <div class="h-timeline-card {% cycle 'above', 'below' %}">
          <div class="h-card-arrow"></div>
          <div class="h-card-date">
            {{ exp.start_date }}{% if exp.end_date and exp.end_date != "" %} — {{ exp.end_date }}{% else %} — Now{% endif %}
          </div>
          <div class="h-card-company">{{ exp.company }}</div>
          <div class="h-card-position">{{ exp.position }}</div>
          {% if exp.location %}
          <div class="h-card-location">{{ exp.location }}</div>
          {% endif %}
        </div>
        <div class="h-timeline-year">{{ exp.start_date | split: '-' | first }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  <div class="h-timeline-fade h-timeline-fade-left"></div>
  <div class="h-timeline-fade h-timeline-fade-right"></div>
  <div class="h-timeline-hint">← drag to explore →</div>
</div>
